# Kalshi API (needed for trading only — market data is public)
# Sign up at kalshi.com → Account Settings → API Keys → Create key → download .pem
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Anthropic (for Claude-powered market matching)
# console.anthropic.com → API Keys → Create key
ANTHROPIC_API_KEY=sk-ant-...your-key-here
USE_CLAUDE_MATCHING=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./arb_scanner.db
